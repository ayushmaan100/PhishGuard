# PhishGuard API — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── ML Service ────────────────────────────────────────────────────────────────
# URL of the Python Flask ML inference service
# Same machine: http://127.0.0.1:5001
# Separate service: https://your-ml-service.railway.app
ML_SERVICE_URL=http://127.0.0.1:5001

# ── Google Safe Browsing ──────────────────────────────────────────────────────
# Get from: console.cloud.google.com → Safe Browsing API → Credentials
# In V2 the extension calls backend → backend calls GSB → key never in extension
GSB_API_KEY=your_gsb_api_key_here

# ── Redis (optional — falls back to in-memory cache) ─────────────────────────
# Railway: add Redis plugin, it sets REDIS_URL automatically
# Local:   redis://localhost:6379
# Upstash: rediss://default:password@host.upstash.io:6379
# REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
# Secret for HMAC-signing install IDs (prevents spoofing)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_SECRET=change_this_to_a_random_64_char_hex_string

# ── Storage ───────────────────────────────────────────────────────────────────
# Where false positive reports are written (JSONL format)
REPORTS_FILE=./data/reports.jsonl

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your web dashboard URL (if you build one)
# FRONTEND_URL=https://phishguard.dev
